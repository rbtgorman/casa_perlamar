<!-- ============================================ -->
<!--                   Footer                     -->
<!-- ============================================ -->

<footer id="footer">
    <div class="container">
        <div class="left-section">
            <a class="logo" href="/"><span class="wordmark">{{ site.name }}</span></a>
            <p class="footer-tagline">{{ site.tagline }}</p>
        </div>
        <div class="right-section">
            <div class="lists">
                <ul>
                    <li><h2>Explore</h2></li>
                    {% for item in site.nav %}
                        <li><a href="{{ item.url }}">{{ item.text }}</a></li>
                    {% endfor %}
                </ul>
                <ul>
                    <li><h2>The Apartment</h2></li>
                    <li>Sleeps {{ apartment.sleeps }}</li>
                    <li>{{ apartment.bedrooms }} bedrooms &middot; {{ apartment.bathrooms }} bathrooms</li>
                    <li>{{ apartment.distanceToBeach }} to the beach</li>
                    <li>{{ site.location }}</li>
                </ul>
                <ul>
                    <li><h2>Contact</h2></li>
                    <li>{{ site.location }}</li>
                    <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
                    <li><a href="/contact/">Booking enquiries</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="credit">
        <span class="copyright">&copy; {{ buildYear }} {{ site.name }}. All rights reserved.</span>
    </div>
</footer>
