---
layout: base.njk
pageCss: reviews
title: Guest Reviews
permalink: /reviews/
---
<section class="content-page">
  <div class="content-container">
    <span class="cs-topper">Reviews</span>
    <h1 class="page-title">What guests say</h1>
    <p class="page-intro">A few words from people who have stayed at Casa Perlamar.</p>

    <div class="rec-grid">
      {% for review in reviews.items %}
        <article class="rec-card review-card">
          <div class="rec-body">
            <p class="rec-rating" aria-label="{{ review.rating }} out of 5">
              {% for i in range(0, 5) %}{% if i < review.rating %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}
            </p>
            <p class="review-text">&ldquo;{{ review.text }}&rdquo;</p>
            <p class="review-author">{{ review.name }} &middot; <span>{{ review.country }}</span></p>
            {% if review.date %}<p class="review-date">{{ review.date }}</p>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    <div class="cs-flex-group button-container">
      <a href="/contact/" class="cs-button-solid">Check availability</a>
    </div>
  </div>
</section>
