---
layout: base.njk
pageCss: about
title: The Apartment
permalink: /about/
---
<section class="content-page">
  <div class="content-container">
    <span class="cs-topper">The Apartment</span>
    <h1 class="page-title">{{ site.name }}</h1>

    {% for para in apartment.description %}
      <p class="page-intro">{{ para }}</p>
    {% endfor %}

    <div class="about-photos">
      {% image "src/images/living-room.jpg", "Living area at Casa Perlamar", "about-photo", "lazy" %}
      {% image "src/images/kitchen.jpg", "Kitchen at Casa Perlamar", "about-photo", "lazy" %}
      {% image "src/images/sea-view.jpg", "Sea view from Casa Perlamar", "about-photo", "lazy" %}
      {% image "src/images/living-room1b.jpg", "Sea view", "gallery-item", "lazy" %}
      {% image "src/images/living-room1c.jpg", "Sea view", "gallery-item", "lazy" %}
      {% image "src/images/bedroom1a.jpg", "Sun terrace", "gallery-item", "lazy" %}
      {% image "src/images/bedroom1b.jpg", "Sea view", "gallery-item", "lazy" %}
      {% image "src/images/bedroom2a.jpg", "Living area", "gallery-item", "lazy" %}
      {% image "src/images/bedroom2b.jpg", "Kitchen", "gallery-item", "lazy" %}
      {% image "src/images/bedroom3a.jpg", "Bedroom", "gallery-item", "lazy" %}
      {% image "src/images/bedroom3b.jpg", "Sun terrace", "gallery-item", "lazy" %}
     
    </div>

    <h2 class="section-heading">At a glance</h2>
    <ul class="facts-grid">
      <li><span class="fact-num">{{ apartment.sleeps }}</span><span class="fact-label">Sleeps</span></li>
      <li><span class="fact-num">{{ apartment.bedrooms }}</span><span class="fact-label">Bedrooms</span></li>
      <li><span class="fact-num">{{ apartment.bathrooms }}</span><span class="fact-label">Bathrooms</span></li>
      <li><span class="fact-num">{{ apartment.distanceToBeach }}</span><span class="fact-label">To the beach</span></li>
    </ul>

    <h2 class="section-heading">Sleeping arrangement</h2>
    <ul class="amenities-list">
      {% for room in apartment.sleeping %}
        <li><strong>{{ room.room }}:</strong> {{ room.beds }}</li>
      {% endfor %}
      <li><strong>Bathrooms:</strong> {{ apartment.bathrooms }} full bathrooms</li>
    </ul>

    <h2 class="section-heading">Amenities</h2>
    <ul class="amenities-list">
      {% for amenity in apartment.amenities %}
        <li>{{ amenity }}</li>
      {% endfor %}
    </ul>

    <h2 class="section-heading">Location</h2>
    <p>{{ site.name }} is right in the heart of {{ site.location }}, a {{ apartment.distanceToBeach }} from Arenal-Bol Beach. Step outside and you're surrounded by beachfront restaurants, tapas bars and cafés, supermarkets and local shops, and the seaside promenade that leads toward the iconic Rock of Ifach. See the <a href="/local-area/">local area guide</a> for more, or our <a href="/recommendations/">recommendations</a> for where to eat and what to see.</p>

    <div class="cs-flex-group button-container">
      <a href="/contact/" class="cs-button-solid">Check availability</a>
    </div>
  </div>
</section>