---
layout: base.njk
pageCss: blog
title: Calpe Travel Tips
permalink: /blog/
---
<section class="content-page">
  <div class="content-container">
    <span class="cs-topper">Blog</span>
    <h1 class="page-title">Calpe travel tips</h1>
    <p class="page-intro">Notes and ideas to help you make the most of your stay.</p>

    <div class="blog-list">
      {% for post in collections.posts | reverse %}
        <article class="blog-card">
          <a class="blog-card-link" href="{{ post.url }}">
            {% if post.data.image %}<img class="blog-card-img" src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.blogTitle }}" loading="lazy" decoding="async">{% endif %}
            <div class="blog-card-body">
              <h2 class="blog-card-title">{{ post.data.blogTitle or post.data.title }}</h2>
              {% if post.data.date %}<p class="post-meta">{{ post.data.date | postDate }}</p>{% endif %}
              {% if post.data.blogDescription %}<p>{{ post.data.blogDescription }}</p>{% endif %}
            </div>
          </a>
        </article>
      {% endfor %}

      {% if not collections.posts | length %}
        <p>No posts yet.</p>
      {% endif %}
    </div>
  </div>
</section>
