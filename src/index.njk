---
layout: base.njk
pageCss: local
title: Casa Perlamar
permalink: /
---

<!-- ============================================ -->
<!--                    Hero                      -->
<!-- ============================================ -->
<section id="hero">
  <div class="cs-container">
    <div class="cs-flex-group">
      <span class="cs-topper">Holiday apartment &middot; {{ site.location }}</span>
      <h1 class="cs-title">{{ site.name }} — your home by the sea in Calpe</h1>
      <p class="cs-text">
        A bright, sea-view apartment in the heart of Calpe, just a one-minute walk from
        Arenal-Bol Beach. Sleeps {{ apartment.sleeps }} across {{ apartment.bedrooms }} bedrooms,
        with a private terrace and everything you need for an easy Mediterranean getaway.
      </p>
      <div class="cs-flex-group button-container">
        <a href="/contact/" class="cs-button-solid">Check availability</a>
        <a href="/gallery/" class="cs-button-solid">View the apartment</a>
      </div>
    </div>
  </div>
  {% image "src/images/hero.jpg", "Casa Perlamar terrace looking out over the sea in Calpe", "cs-picture", "eager" %}
</section>

<!-- ============================================ -->
<!--                  Key Facts                   -->
<!-- ============================================ -->
<section id="key-facts">
  <div class="cs-container">
    <ul class="facts-grid">
      <li><span class="fact-num">{{ apartment.sleeps }}</span><span class="fact-label">Sleeps</span></li>
      <li><span class="fact-num">{{ apartment.bedrooms }}</span><span class="fact-label">Bedrooms</span></li>
      <li><span class="fact-num">{{ apartment.bathrooms }}</span><span class="fact-label">Bathrooms</span></li>
      <li><span class="fact-num">{{ apartment.distanceToBeach }}</span><span class="fact-label">To the beach</span></li>
    </ul>
  </div>
</section>

<!-- ============================================ -->
<!--                  Features                    -->
<!-- ============================================ -->
<section id="features">
  <div class="cs-container">
    <span class="cs-topper">Why stay here</span>
    <h2 class="cs-title">Everything you need, steps from the sand</h2>
    <div class="features-grid">
      <div class="feature-card">
        <img src="/assets/svgs/service1.svg" aria-hidden="true" decoding="async" alt="" width="48" height="48">
        <h3>Sea-view terrace</h3>
        <p>Start the morning with coffee and a Mediterranean view, and unwind in the evening sun.</p>
      </div>
      <div class="feature-card">
        <img src="/assets/svgs/service2.svg" aria-hidden="true" decoding="async" alt="" width="48" height="48">
        <h3>Walk to the beach</h3>
        <p>Calpe's sandy beaches, marina and old town are all within an easy stroll of the door.</p>
      </div>
      <div class="feature-card">
        <img src="/assets/svgs/service3.svg" aria-hidden="true" decoding="async" alt="" width="48" height="48">
        <h3>Comfortable &amp; equipped</h3>
        <p>Air conditioning, fast fibre WiFi and a fully equipped kitchen — set up for a relaxed stay.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!--                Gallery Teaser                -->
<!-- ============================================ -->
<section id="gallery">
  <div class="cs-container">
    <span class="cs-topper">Take a look</span>
    <h2 class="cs-title">Inside Casa Perlamar</h2>
    <div class="cs-image-group">
      <div class="cs-row cs-row-1">
        {% image "src/images/living-room.jpg", "Living area at Casa Perlamar", "cs-picture cs-picture-1", "lazy" %}
        {% image "src/images/bedroom.jpg", "Bedroom at Casa Perlamar", "cs-picture cs-picture-2", "lazy" %}
        {% image "src/images/sea-view.jpg", "Sun terrace at Casa Perlamar", "cs-picture cs-picture-3", "lazy" %}
      </div>
    </div>
    <a href="/gallery/" class="cs-button-solid">View more photos</a>
  </div>
</section>

<!-- ============================================ -->
<!--                Explore Calpe                 -->
<!-- ============================================ -->
<section id="explore">
  <div class="cs-container">
    <span class="cs-topper">Make the most of your stay</span>
    <h2 class="cs-title">Explore Calpe</h2>
    <div class="features-grid">
      <a class="feature-card link-card" href="/local-area/">
        <h3>Local area &rarr;</h3>
        <p>Getting here, the beaches, the climate and how to get around Calpe.</p>
      </a>
      <a class="feature-card link-card" href="/recommendations/">
        <h3>Recommendations &rarr;</h3>
        <p>Our favourite restaurants, bars, beaches and day trips around town.</p>
      </a>
      <a class="feature-card link-card" href="/contact/">
        <h3>Book your stay &rarr;</h3>
        <p>Send us your dates and we'll get back to you about availability.</p>
      </a>
    </div>
  </div>
</section>
